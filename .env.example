APP_NAME=Gulf Situation AI Monitor
ENVIRONMENT=development
BACKEND_PORT=8001
DATABASE_URL=postgresql+psycopg://gulf_user:gulf_pass@postgres:5432/gulf_monitor
POLL_SECONDS=120
USE_REDIS_WORKER=true
REDIS_URL=redis://redis:6379/0
INGEST_QUEUE_NAME=ingestion

# API auth for backend + frontend
API_KEY_ENABLED=true
APP_API_KEY=replace-with-a-strong-secret-key

# Optional AI provider settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PRIVACY_MODE=true
REPORTS_DIR=./data/reports
TRUSTED_DOMAINS=cnn.com,edition.cnn.com,alarabiya.net,gulfnews.com,news.sky.com,skynews.com,skynewsarabia.com,bbc.com,france24.com,arabic.rt.com,rt.com,independentarabia.com,reliefweb.int,gdacs.org,cisa.gov,opensky-network.org,marinetraffic.com,flightradar24.com,reddit.com

# Official provider credentials (optional but recommended for licensed integrations)
FR24_API_KEY=
FR24_AUTH_HEADER=x-apikey
FR24_API_KEY_PARAM=
MARINETRAFFIC_API_KEY=
MARINETRAFFIC_AUTH_HEADER=
MARINETRAFFIC_API_KEY_PARAM=api_key
NEWSDATA_API_KEY=
GNEWS_API_KEY=
NEWSAPI_API_KEY=
APIFY_TOKEN=

# Optional frontend live-video overrides (embeddable URLs)
VITE_SKY_ARABIA_YT_EMBED_URL=
VITE_ALJAZEERA_AR_EMBED_URL=
VITE_ALARABIYA_EMBED_URL=
VITE_SKY_ARABIA_EMBED_URL=

# Gulf relevance defaults
GULF_KEYWORDS=gulf,hormuz,uae,saudi,bahrain,kuwait,qatar,oman,iran,iraq,yemen,dubai,abu dhabi,doha,riyadh,muscat,manama,basra
GULF_MIN_LAT=16
GULF_MAX_LAT=32
GULF_MIN_LON=45
GULF_MAX_LON=60

# Optional default source endpoints
DEFAULT_NEWS_RSS=https://reliefweb.int/updates?format=rss
DEFAULT_NEWS_PARSER_HINT=rss
DEFAULT_INCIDENT_FEED=https://www.gdacs.org/xml/rss.xml
DEFAULT_INCIDENT_PARSER_HINT=rss
DEFAULT_FLIGHT_FEED=https://opensky-network.org/api/states/all
DEFAULT_FLIGHT_PARSER_HINT=opensky
DEFAULT_MARINE_FEED=
DEFAULT_MARINE_PARSER_HINT=marinetraffic
DEFAULT_CYBER_FEED=https://www.cisa.gov/news-events/cybersecurity-advisories.xml
DEFAULT_CYBER_PARSER_HINT=cyber_rss
DEFAULT_SOCIAL_FEED=
DEFAULT_SOCIAL_PARSER_HINT=social_reddit_json
DEFAULT_CNN_GULF_FEED=https://news.google.com/rss/search?q=site:cnn.com%20(gulf%20OR%20middle%20east%20war)&hl=en-US&gl=US&ceid=US:en
DEFAULT_ALARABIYA_GULF_FEED=https://news.google.com/rss/search?q=site:alarabiya.net%20(gulf%20OR%20middle%20east%20war)&hl=en-US&gl=US&ceid=US:en
DEFAULT_GULFNEWS_FEED=https://news.google.com/rss/search?q=site:gulfnews.com%20(gulf%20OR%20middle%20east%20war)&hl=en-US&gl=US&ceid=US:en
DEFAULT_BBC_ARABIC_FEED=https://www.bbc.com/arabic/index.xml
DEFAULT_FRANCE24_AR_FEED=https://www.france24.com/ar/rss
DEFAULT_RT_ARABIC_FEED=https://arabic.rt.com/rss/
DEFAULT_INDEPENDENTARABIA_FEED=https://www.independentarabia.com/rss.xml
