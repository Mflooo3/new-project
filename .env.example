APP_NAME=Gulf Situation AI Monitor
ENVIRONMENT=development
BACKEND_PORT=8001
POSTGRES_DB=gulf_monitor
POSTGRES_USER=gulf_user
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql+psycopg://gulf_user:gulf_pass@postgres:5432/gulf_monitor
CORS_ORIGINS=*
POLL_SECONDS=120
PREDICTION_REVIEW_SECONDS=300
PREDICTION_REVIEW_MIN_INTERVAL_MINUTES=5
NEWS_MAX_AGE_HOURS=24
USE_REDIS_WORKER=true
REDIS_URL=redis://redis:6379/0
INGEST_QUEUE_NAME=ingestion

# Auth/IAM (registration + admin approval)
AUTH_REQUIRED=true
AUTH_STRATEGY=hybrid
AUTH_PASSWORD_ENABLED=true
AUTH_EMAIL_OTP_ENABLED=true
AUTH_MOBILE_ENABLED=false
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=14
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_JWT_ALG=HS256
AUTH_OTP_MINUTES=10
PASSWORD_RESET_TOKEN_MINUTES=30
PASSWORD_RESET_URL_TEMPLATE=http://localhost:5174/?auth=reset&token={token}
OTP_EXPIRY_MINUTES=
OTP_RESEND_COOLDOWN_SECONDS=60
TOTP_ISSUER_NAME=
TOTP_STEP_SECONDS=30
TOTP_DIGITS=6
TOTP_MAX_FAILED_ATTEMPTS=5
TOTP_LOCK_SECONDS=60
AUTH_MAX_FAILED_ATTEMPTS=6
AUTH_LOCK_MINUTES=15
SESSION_IDLE_TIMEOUT_MINUTES=120
ACTIVE_USER_WINDOW_DAYS=30
DEFAULT_API_USAGE_UNIT_COST=0.0
DEFAULT_TENANT_NAME=Default Workspace
DEFAULT_TENANT_SLUG=default-workspace
SUPER_ADMIN_NAME=Platform Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
EMAIL_OTP_SENDER=
SES_FROM_EMAIL=
SES_FROM_NAME=
EMAIL_PROVIDER=console
SENDGRID_API_KEY=
AWS_REGION=
AWS_SES_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_SES_CONFIGURATION_SET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# Frontend runtime/build API target
# Local dev example:
# VITE_API_BASE_URL=http://localhost:8012
# Production behind nginx reverse-proxy:
# VITE_API_BASE_URL=/api
VITE_API_BASE_URL=http://localhost:8012
VITE_API_BASE_URL_PROD=/api
VITE_API_REQUEST_TIMEOUT_MS=45000
VITE_LOGOUT_REQUEST_TIMEOUT_MS=3500

# Optional API key fallback mode (legacy)
API_KEY_ENABLED=false
APP_API_KEY=

# Optional AI provider settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_INPUT_COST_PER_1M_TOKENS=0
OPENAI_OUTPUT_COST_PER_1M_TOKENS=0
X_API_CALL_COST=0
AI_PRIVACY_MODE=true
OCR_ENABLED=true
OCR_ONLY_THREAT_SIGNALS=false
OCR_MAX_IMAGES_PER_EVENT=1
OCR_MAX_CHARS=900
OCR_VISION_MODEL=
REPORTS_DIR=./data/reports
TRUSTED_DOMAINS=cnn.com,edition.cnn.com,alarabiya.net,gulfnews.com,khaleejtimes.com,emirates247.com,thenationalnews.com,wam.ae,news.sky.com,skynews.com,skynewsarabia.com,bbc.com,france24.com,arabic.rt.com,rt.com,independentarabia.com,reliefweb.int,gdacs.org,cisa.gov,opensky-network.org,api.jsoncargo.com,jsoncargo.com,marinetraffic.com,flightradar24.com,reddit.com

# Official provider credentials (optional but recommended for licensed integrations)
FR24_API_KEY=
FR24_AUTH_HEADER=Authorization
FR24_AUTH_SCHEME=Bearer
FR24_ACCEPT_VERSION=v1
FR24_API_KEY_PARAM=
JSONCARGO_API_KEY=
JSONCARGO_AUTH_HEADER=x-api-key
JSONCARGO_API_KEY_PARAM=
MARINETRAFFIC_API_KEY=
MARINETRAFFIC_AUTH_HEADER=
MARINETRAFFIC_API_KEY_PARAM=api_key
NEWSDATA_API_KEY=
GNEWS_API_KEY=
NEWSAPI_API_KEY=
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1
AVIATIONSTACK_REQUEST_LIMIT=60
COMTRADE_API_KEY=
COMTRADE_BASE_URL=https://comtradeapi.worldbank.org
X_API_KEY=
X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com/2
APIFY_TOKEN=

# Optional frontend live-video overrides (embeddable URLs)
VITE_SKY_ARABIA_YT_EMBED_URL=
VITE_ALJAZEERA_AR_EMBED_URL=
VITE_ALARABIYA_EMBED_URL=
VITE_SKY_ARABIA_EMBED_URL=
VITE_NEWS_MAX_AGE_HOURS=24

# Gulf relevance defaults
GULF_KEYWORDS=gulf,hormuz,uae,saudi,bahrain,kuwait,qatar,oman,iran,iraq,yemen,dubai,abu dhabi,doha,riyadh,muscat,manama,basra
GULF_MIN_LAT=16
GULF_MAX_LAT=32
GULF_MIN_LON=45
GULF_MAX_LON=60

# Optional default source endpoints
DEFAULT_NEWS_RSS=https://reliefweb.int/updates?format=rss
DEFAULT_NEWS_PARSER_HINT=rss
DEFAULT_INCIDENT_FEED=https://www.gdacs.org/xml/rss.xml
DEFAULT_INCIDENT_PARSER_HINT=rss
DEFAULT_FLIGHT_FEED=https://opensky-network.org/api/states/all
DEFAULT_FLIGHT_PARSER_HINT=opensky
DEFAULT_MARINE_FEED=
DEFAULT_MARINE_PARSER_HINT=jsoncargo
DEFAULT_CYBER_FEED=https://www.cisa.gov/news-events/cybersecurity-advisories.xml
DEFAULT_CYBER_PARSER_HINT=cyber_rss
DEFAULT_SOCIAL_FEED=
DEFAULT_SOCIAL_PARSER_HINT=social_reddit_json
DEFAULT_X_RECENT_FEED=
DEFAULT_X_RECENT_PARSER_HINT=x_recent
DEFAULT_CNN_GULF_FEED=https://news.google.com/rss/search?q=site:cnn.com%20(gulf%20OR%20middle%20east%20war)&hl=en-US&gl=US&ceid=US:en
DEFAULT_ALARABIYA_GULF_FEED=https://news.google.com/rss/search?q=site:alarabiya.net%20(gulf%20OR%20middle%20east%20war)&hl=en-US&gl=US&ceid=US:en
DEFAULT_GULFNEWS_FEED=https://news.google.com/rss/search?q=site:gulfnews.com%20(gulf%20OR%20middle%20east%20war)&hl=en-US&gl=US&ceid=US:en
DEFAULT_BBC_ARABIC_FEED=https://www.bbc.com/arabic/index.xml
DEFAULT_FRANCE24_AR_FEED=https://www.france24.com/ar/rss
DEFAULT_RT_ARABIC_FEED=https://arabic.rt.com/rss/
DEFAULT_INDEPENDENTARABIA_FEED=https://www.independentarabia.com/rss.xml
